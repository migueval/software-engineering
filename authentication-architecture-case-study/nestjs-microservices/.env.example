PORT=3001
JWT_SECRET=your-super-secret-key-change-this-in-production

# PostgreSQL Database Connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_case_study

# Redis Connection (Auth OTP Caching)
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ Event Broker Connection
RABBITMQ_URL=amqp://localhost:5672

# Nodemailer SMTP Configuration (Optional - Falls back to Ethereal Mail if blank)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
